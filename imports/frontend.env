# =============================================================================
# NL Portal Frontend Configuration
# =============================================================================
# Variables are injected into window.* at runtime via config.js/config.template.js.
# Pattern: window.VAR_NAME in browser, VAR_NAME in this file.
# =============================================================================

# -----------------------------------------------------------------------------
# API Endpoints (required)
# -----------------------------------------------------------------------------
GRAPHQL_URI=http://localhost:8080/graphql
REST_URI=http://localhost:8080/api

# -----------------------------------------------------------------------------
# OIDC Authentication (required)
# -----------------------------------------------------------------------------
OIDC_URL=http://localhost:8082/auth
OIDC_REALM=nlportal
OIDC_CLIENT_ID=nl-portal
OIDC_REDIRECT_URI=http://localhost:3000/oidc/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000

# -----------------------------------------------------------------------------
# OIDC Session Management (optional)
# Idle logout enabled by default (15 min). Set to false to disable.
# -----------------------------------------------------------------------------
OIDC_AUTO_IDLE_SESSION_LOGOUT=true
OIDC_IDLE_TIMEOUT_MINUTES=15

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
USE_THEME_API=true
OPEN_KLANT_VERSION=v2
MESSAGE_COUNT_ENABLE=true
MESSAGE_COUNT_POLLING_INTERVAL=10000
CASES_PARTIAL_SEARCH=true
SHOW_INHABITANT_AMOUNT=true
OPEN_PRODUCTEN=false
SHOW_CASE_RESULT_EXPLANATION=false
#USE_LEGACY_OGONE_PAYMENT=false

# -----------------------------------------------------------------------------
# Overview Page Options
# -----------------------------------------------------------------------------
#OVERVIEW_SHOW_INTRO=true
#OVERVIEW_SHOW_MAINTENANCE_ALERT=true
#OVERVIEW_SHOW_CURRENT_CASES_PREVIEW=true
#OVERVIEW_CURRENT_CASES_PREVIEW_LENGTH=4

# -----------------------------------------------------------------------------
# Account Page Options
# -----------------------------------------------------------------------------
#ACCOUNT_SHOW_NOTIFICATION_SUBSECTION=false

# -----------------------------------------------------------------------------
# Theme (optional)
# -----------------------------------------------------------------------------
#THEME_CLASS=

# -----------------------------------------------------------------------------
# BRP/Address Action URLs (optional)
# External links shown on account page
# -----------------------------------------------------------------------------
#ADDRESS_RESEARCH_URL=https://nl-portal.nl
#ADDRESS_RESEARCH_MORE_INFO_URL=https://nl-portal.nl
#REPORT_CHANGE_OF_ADDRESS_URL=https://nl-portal.nl
#CHANGE_IN_USE_OF_SURNAME_URL=https://nl-portal.nl
#CHANGE_REGISTERED_GENDER_URL=https://nl-portal.nl
#REQUEST_FOR_CHANGE_BRP_INFO_URL=https://nl-portal.nl
#REQUEST_CONFIDENTIALITY_OF_DATA_URL=https://nl-portal.nl
