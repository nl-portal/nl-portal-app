NLPORTAL_CONFIG_OBJECTENAPI_ENABLED=true
NLPORTAL_CONFIG_OBJECTENAPI_PROPERTIES_URL=http://localhost:8010
NLPORTAL_CONFIG_OBJECTENAPI_PROPERTIES_TOKEN=182c13e2209161852c53cef53a879f7a2f923430

# -----------------------------------------------------------------------------
