# =============================================================================
# NL Portal Backend Configuration
# =============================================================================
# This file configures the Spring Boot backend for nl-portal-app.
# Environment variables follow Spring Boot relaxed binding:
#   nl-portal.config.module.property → NLPORTAL_CONFIG_MODULE_PROPERTY
#
# Required services (docker-compose profiles):
#   - Database: always required
#   - Keycloak: always required
#   - zgw: OpenZaak, ObjectenAPI, etc.
#   - haalcentraal: BRP/Bewoning mocks
#   - config: Configuration Panel
# =============================================================================

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DATABASE_URL=jdbc:postgresql://localhost:5432/nl-portal
DATABASE_USERNAME=nlportal
DATABASE_PASSWORD=password

# -----------------------------------------------------------------------------
# Spring Cloud Config (Configuration Panel)
# -----------------------------------------------------------------------------
CONFIGURATION_PANEL_ENABLED=true
CONFIGURATION_PANEL_TOKEN=VerySecretToken
CONFIGURATION_PANEL_URI=http://host.docker.internal:8090/configuration
CONFIGURATION_PANEL_APPLICATION_NAME=nl-portal-app

# -----------------------------------------------------------------------------
# Authentication - Keycloak
# -----------------------------------------------------------------------------
JWKS_URI=http://localhost:8082/auth/realms/nlportal/protocol/openid-connect/certs
KEYCLOAK_CLIENT_ID=nl-portal-m2m
KEYCLOAK_CLIENT_SECRET=ookVRUAxmEWMcosfcGR5nxeoUC4Rgwbc
KEYCLOAK_TOKEN_EXCHANGE_AUDIENCE=nl-portal-token-exchange
#NLPORTAL_AUTHENTICATION_KEYCLOAK_RESOURCE=
#NLPORTAL_AUTHENTICATION_KEYCLOAK_AUDIENCE=
#NLPORTAL_AUTHENTICATION_KEYCLOAK_CREDENTIALS_SECRET=

# -----------------------------------------------------------------------------
# Authentication - Machtigingsdienst (optional)
# -----------------------------------------------------------------------------
#NLPORTAL_AUTHENTICATION_MACHTINGSDIENST_RESOURCEURL=
#NLPORTAL_AUTHENTICATION_MACHTINGSDIENST_ALLMACHTIGINGUUID=

# -----------------------------------------------------------------------------
# Security - CORS (optional)
# -----------------------------------------------------------------------------
#NLPORTAL_SECURITY_CORS_0_PATH=/**
#NLPORTAL_SECURITY_CORS_0_CONFIG_ALLOWEDORIGINS=*
#NLPORTAL_SECURITY_CORS_0_CONFIG_ALLOWEDMETHODS=GET,POST,PUT,DELETE,OPTIONS
#NLPORTAL_SECURITY_CORS_0_CONFIG_ALLOWEDHEADERS=*

# -----------------------------------------------------------------------------
# Security - Endpoints (optional)
# -----------------------------------------------------------------------------
#NLPORTAL_SECURITY_ENDPOINTS_UNSECURED=/actuator/health

# -----------------------------------------------------------------------------
# Security - Headers (optional)
# -----------------------------------------------------------------------------
#NLPORTAL_SECURITY_HEADERS_CONTENTSECURITYPOLICY=default-src 'self'
#NLPORTAL_SECURITY_HEADERS_HSTSMAXAGEINDAYS=365

# -----------------------------------------------------------------------------
# Theme (optional)
# -----------------------------------------------------------------------------
#NLPORTAL_CONFIG_THEME_STYLE=
#NLPORTAL_CONFIG_THEME_LOGO=

