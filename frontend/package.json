{
  "name": "nl-portal-app",
  "version": "3.0.3",
  "author": "Ritense",
  "packageManager": "pnpm",
  "license": "EUPL-1.2",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.30.0 <11"
  },
  "scripts": {
    "dev": "vite --port 3000 --mode development",
    "build": "tsc && vite build",
    "preinstall": "npx only-allow pnpm",
    "preview": "vite preview --port 3000",
    "generate-pwa-assets": "pwa-asset-generator ./src/assets/pwa-logo.svg ./public/pwa --favicon --mstile --opaque  false --maskable true --index  index.html --manifest ./public/manifest.json --path-override '../pwa'",
    "clean": "rimraf build",
    "lint": "eslint .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@apollo/client": "3.13.8",
    "@gemeente-denhaag/design-tokens-components": "5.1.0",
    "@gemeente-denhaag/icons": "4.0.0",
    "@nl-portal/nl-portal-api": "https://nl-portal-frontend-snapshots.s3.eu-central-1.amazonaws.com/3.0.3-RC-202606171128-e0c27fec-SNAPSHOT/nl-portal-nl-portal-api.tgz",
    "@nl-portal/nl-portal-authentication": "https://nl-portal-frontend-snapshots.s3.eu-central-1.amazonaws.com/3.0.3-RC-202606171128-e0c27fec-SNAPSHOT/nl-portal-nl-portal-authentication.tgz",
    "@nl-portal/nl-portal-localization": "https://nl-portal-frontend-snapshots.s3.eu-central-1.amazonaws.com/3.0.3-RC-202606171128-e0c27fec-SNAPSHOT/nl-portal-nl-portal-localization.tgz",
    "@nl-portal/nl-portal-user-interface": "https://nl-portal-frontend-snapshots.s3.eu-central-1.amazonaws.com/3.0.3-RC-202606171128-e0c27fec-SNAPSHOT/nl-portal-nl-portal-user-interface.tgz",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-intl": "7.1.14",
    "react-router": "7.16.0"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.60.1",
    "@typescript-eslint/parser": "8.60.1",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "globals": "16.4.0",
    "jsdom": "29.1.1",
    "pwa-asset-generator": "8.1.5",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "vite": "7.3.5",
    "vitest": "4.1.8"
  },
  "pnpm": {
    "overrides": {
      "@babel/core": "7.29.6",
      "esbuild": "0.28.1",
      "rollup": "4.59.0",
      "flatted": "3.4.2",
      "dompurify": "3.4.9",
      "js-cookie": "3.0.7",
      "basic-ftp": "5.3.1",
      "uuid": "11.1.1",
      "picomatch@2": "2.3.2",
      "picomatch@4": "4.0.4",
      "minimatch@<3.1.4": "3.1.4",
      "brace-expansion@<1.1.13": "1.1.13",
      "lodash-es@>=4.0.0 <=4.17.23": "4.18.0",
      "lodash@>=4.0.0 <=4.17.23": "4.18.0",
      "postcss@<8.5.10": "8.5.10"
    }
  }
}
